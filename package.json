{
  "name": "hermes-for-pebble",
  "author": "Hermes",
  "version": "0.6.3",
  "keywords": [
    "pebble-app"
  ],
  "private": true,
  "dependencies": {
    "pebble-clay": "^1.0.4"
  },
  "pebble": {
    "displayName": "Hermes for Pebble",
    "uuid": "24484c4e-36c2-4486-8eaf-e8ff0417ff82",
    "sdkVersion": "3",
    "enableMultiJS": true,
    "targetPlatforms": [
      "basalt",
      "chalk",
      "diorite",
      "emery"
    ],
    "capabilities": [
      "microphone",
      "configurable"
    ],
    "watchapp": {
      "watchface": false
    },
    "messageKeys": [
      "PROMPT",
      "REPLY_CHUNK",
      "REPLY_DONE",
      "REPLY_PARTS",
      "REPLY_BYTES",
      "STATUS",
      "NO_THINK",
      "VIBE",
      "VIBRATE_CFG"
    ],
    "resources": {
      "media": [
        {
          "type": "bitmap",
          "name": "IMAGE_HERMES_LOGO",
          "file": "hermes_logo.png"
        }
      ]
    }
  }
}
