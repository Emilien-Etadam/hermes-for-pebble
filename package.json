        {
          "type": "png",
          "name": "ACTION_DOWN",
          "file": "action_down.png"
        },
        {
          "type": "png",
          "name": "ACTION_MIC",
          "file": "action_mic.png"
        },
        {
          "type": "png",
          "name": "ACTION_HISTORY",
          "file": "action_history.png"
        },
        {
          "type": "png",
          "name": "ACTION_READ",
          "file": "action_read.png"
        },
        {
          "type": "png",
